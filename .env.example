# Copie este arquivo para .env e preencha com seus dados.

# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=drive_teste
PGUSER=postgres
PGPASSWORD=troque_aqui

# --- Google ---
# Caminho do arquivo baixado do Google Cloud Console (OAuth client - Desktop app)
GOOGLE_CREDENTIALS_FILE=credentials.json
# Onde o token de acesso do usuario sera salvo apos o primeiro login
GOOGLE_TOKEN_FILE=token.json

# Pasta local onde os downloads do Drive serao salvos
DOWNLOAD_DIR=downloads
